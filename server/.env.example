PORT=5000
NODE_ENV=development

# Neon Postgres (get from neon.tech dashboard)
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/sizzld_db?sslmode=require&pgbouncer=true
DIRECT_URL=postgresql://user:password@ep-xxx.neon.tech/sizzld_db?sslmode=require

# Upstash Redis (get from upstash.com dashboard)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# JWT
JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here

# CORS origins
CLIENT_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
PRODUCTION_CLIENT_URL=https://sizzld.vercel.app
PRODUCTION_ADMIN_URL=https://sizzld-admin.vercel.app